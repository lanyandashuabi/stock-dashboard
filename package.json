{
  "name": "stock-dashboard",
  "version": "2.4.0",
  "description": "个人股票复盘网站 - A股/港股研究看板",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node --import tsx server/index.ts",
    "tunnel": "bash scripts/tunnel.sh",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000/api/health && electron .\"",
    "electron:build": "npm run build && electron-builder --config electron-builder.yml",
    "electron:build:win": "npm run build && electron-builder --config electron-builder.yml --win",
    "electron:build:mac": "npm run build && electron-builder --config electron-builder.yml --mac",
    "electron:build:linux": "npm run build && electron-builder --config electron-builder.yml --linux"
  },
  "keywords": [
    "stock",
    "dashboard",
    "A-share",
    "HK-stock"
  ],
  "author": "Stock Dashboard <stock@dashboard.local>",
  "homepage": "http://localhost:3000",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.3",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.14"
  }
}
